# =============================================================================
# MM-Hub Environment Variables
# Copy this file to .env.local and fill in all values
# =============================================================================

# --- Supabase ---
# Project URL and anon key from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to client
# Supabase dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- Microsoft Entra ID (Azure AD) ---
# Configure in Supabase dashboard → Authentication → Providers → Azure
# These are for reference only — Supabase handles the OAuth flow
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# --- FreshTrack ---
# Read-only connection to FreshTrack AWS RDS PostgreSQL
# Format: postgresql://user:password@host:5432/database?sslmode=require
FRESHTRACK_DATABASE_URL=postgresql://cloud_mackaysmarketing_readonly:PASSWORD@fts-cloud-prod-rds.c1unadkiffrs.ap-southeast-2.rds.amazonaws.com:5432/cloud_mackaysmarketing?sslmode=require

# --- FreshTrack GraphQL sync (new path, replaces v_power_bi_* RDS sync) ---
# Feature flag — sync stays disabled (cron returns {status:"disabled"})
# unless this is exactly "true". Default off so a misconfigured deploy is
# a no-op rather than a broken partial run.
# FRESHTRACK_GRAPHQL_SYNC_ENABLED=
# GraphQL endpoint (optional override; defaults to the public mackays URL)
# FT_GRAPHQL_URL=https://mackaysmarketing.freshtrack.com/api/graphql
# Read+write user; create a dedicated admin user in FT Cloud rather than
# reusing a person's login. Never exposed to client.
FT_GRAPHQL_EMAIL=
FT_GRAPHQL_PASSWORD=
# Mackays Marketing's marketer-role UUID (verified live 2026-06-08).
# Used to filter dispatchLoads down to dispatches Mackays markets.
FT_MACKM_MARKETER_ID=0192035b-0cf8-4e5f-8675-e6144ff7df99

# --- NetSuite ---
# SuiteTalk REST Web Services — Token-Based Authentication (TBA)
# All values from NetSuite → Setup → Integration → Manage Integrations
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# Feature flag — keeps the NetSuite RCTI sync DISABLED until the raw-data
# consolidation pipeline (SY-1/2/4/5) is rebuilt. The cron handler returns
# 200 {status:"disabled"} unless this is the literal string "true". RCTIs
# are currently served via on-demand PDF upload (see HANDOFF.md), so leave
# this unset until the proper sync is wired against the verified raw-data
# export from Finance.
# NETSUITE_SYNC_ENABLED=

# --- Subdomain Routing ---
# Production subdomains for portal mode detection
# These override hostname-based detection for custom domain setups
NEXT_PUBLIC_GROWER_DOMAIN=grower.mackaysmarketing.com.au
NEXT_PUBLIC_HUB_DOMAIN=hub.mackaysmarketing.com.au

# --- Vercel Cron ---
# Secret token to authenticate /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=

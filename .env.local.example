# =============================================================================
# MM-Hub Environment Variables
# Copy this file to .env.local and fill in all values
# =============================================================================

# --- Supabase ---
# Project URL and anon key from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, never expose to client
# Supabase dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- Microsoft Entra ID (Azure AD) ---
# Configure in Supabase dashboard → Authentication → Providers → Azure
# These are for reference only — Supabase handles the OAuth flow
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# --- FreshTrack ---
# Read-only connection to FreshTrack AWS RDS PostgreSQL
# Format: postgresql://user:password@host:5432/database?sslmode=require
FRESHTRACK_DATABASE_URL=postgresql://cloud_mackaysmarketing_readonly:PASSWORD@fts-cloud-prod-rds.c1unadkiffrs.ap-southeast-2.rds.amazonaws.com:5432/cloud_mackaysmarketing?sslmode=require

# --- NetSuite ---
# SuiteTalk REST Web Services — Token-Based Authentication (TBA)
# All values from NetSuite → Setup → Integration → Manage Integrations
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# --- Subdomain Routing ---
# Production subdomains for portal mode detection
# These override hostname-based detection for custom domain setups
NEXT_PUBLIC_GROWER_DOMAIN=grower.mackaysmarketing.com.au
NEXT_PUBLIC_HUB_DOMAIN=hub.mackaysmarketing.com.au

# --- Vercel Cron ---
# Secret token to authenticate /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=
